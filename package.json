{
  "name": "ban",
  "version": "0.1.0",
  "description": "Local-first Kanban for developers",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -n next,tsc,electron -c cyan,yellow,green \"next dev\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "build": "next build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "gray-matter": "^4.0.3",
    "nanoid": "^3.3.7",
    "slugify": "^1.6.6",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@hugeicons/react": "^1.1.7",
    "@tailwindcss/typography": "^0.5.15",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "framer-motion": "^11.2.12",
    "next": "^14.2.4",
    "postcss": "^8.4.38",
    "rcedit": "^5.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.ban.kanban-capture",
    "productName": "Ban",
    "afterPack": "./scripts/after-pack.js",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "packElevateHelper": false
    }
  }
}
